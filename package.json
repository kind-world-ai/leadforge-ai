{
  "name": "leadforge-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack -p 3020",
    "build": "next build --webpack",
    "start": "next start -p 3020",
    "worker:build": "esbuild worker/index.ts --bundle --platform=node --packages=external --alias:@=. --outfile=worker/.build/worker.cjs",
    "worker": "npm run worker:build && node --env-file=.env.local worker/.build/worker.cjs",
    "lint": "next lint"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "better-sqlite3": "^12.10.0",
    "lucide-react": "0.427.0",
    "next": "^16.2.9",
    "playwright": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.21.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "20.14.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "10.4.20",
    "esbuild": "^0.28.0",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.10",
    "typescript": "5.5.4"
  }
}
