GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
# Optional. PageSpeed works without a key at low volume; add one to avoid rate limits.
# Enable "PageSpeed Insights API" in Google Cloud. Can be the same key as Places.
PAGESPEED_API_KEY=

# ABN Lookup (Australia) - free GUID from abr.business.gov.au/Tools/WebServices
ABN_LOOKUP_GUID=

# ===== Shared online mode (Supabase) =====
# Default is local SQLite. Set DATA_BACKEND=supabase to use the shared online database.
DATA_BACKEND=sqlite
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server/worker only - NEVER expose this in client code
SUPABASE_SERVICE_ROLE_KEY=

# Web enrichment ("Find profiles") - pick ONE provider:
# Brave Search API: free 2000 queries/month at brave.com/search/api
BRAVE_SEARCH_API_KEY=
# OR Google Programmable Search: programmablesearchengine.google.com (search entire web)
GOOGLE_CSE_ID=
GOOGLE_CSE_API_KEY=

# Branding for the client-facing Audit PDF
AGENCY_NAME=Bitpixel Coders
AGENCY_TAGLINE=Websites, SEO & Automation for growing businesses
AGENCY_EMAIL=
AGENCY_PHONE=
AGENCY_WEBSITE=
AGENCY_ACCENT=#d97757

# AI Outreach Writer (F2) - get a key at console.anthropic.com
ANTHROPIC_API_KEY=
# Optional, defaults to claude-sonnet-4-6
ANTHROPIC_MODEL=
